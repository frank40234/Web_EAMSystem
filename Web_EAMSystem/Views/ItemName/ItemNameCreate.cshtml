@model Web_EAMSystem.Models.ItemName

@{
    ViewData["Title"] = "新增品名資料";
}

<h2>新增品名資料</h2>
<hr />

<div class="row">
    <div class="col-md-4">
        <form asp-action="ItemNameCreate">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="SUB_CAT_CODE" class="control-label">所屬大類</label>
                <select asp-for="SUB_CAT_CODE" id="subCategorySelect" class="form-select" asp-items="@ViewBag.SubCategoryList">
                    <option value="">-- 請選擇所屬大類 --</option>
                </select>
                <span asp-validation-for="SUB_CAT_CODE" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="IN_CODE" class="control-label">品名代號</label>
                <input asp-for="IN_CODE" class="form-control" />
                <span asp-validation-for="IN_CODE" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="IN" class="control-label">品名</label>
                <input asp-for="IN" class="form-control" />
                <span asp-validation-for="IN" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="存檔並送出" class="btn btn-primary" />
                <a asp-action="ItemNameIndex" class="btn btn-secondary">返回列表</a>
            </div>

        </form>
    </div>
</div>
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // 等待 HTML 畫面完全載入後執行
        document.addEventListener("DOMContentLoaded", function () {

            // 從後端接收成功或錯誤訊息 (Razor 語法轉成 JavaScript 字串)
            var successMsg = '@Html.Raw(TempData["SuccessMessage"])';
            var errorMsg = '@Html.Raw(TempData["ErrorMessage"])';

            // 如果有成功訊息，彈出綠色打勾視窗
            if (successMsg) {
                Swal.fire({
                    icon: 'success',
                    title: '成功！',
                    text: successMsg,
                    confirmButtonColor: '#3085d6'
                });
            }

            // 如果有錯誤訊息，彈出紅色叉叉視窗
            if (errorMsg) {
                Swal.fire({
                    icon: 'error',
                    title: '新增失敗！',
                    text: errorMsg,
                    confirmButtonColor: '#d33'
                });
            }
        });
    </script>
}