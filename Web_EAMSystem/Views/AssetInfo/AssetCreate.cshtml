@model Web_EAMSystem.Models.AssetInfo

@{
    ViewData["Title"] = "新增物料清單";
}

<h2>新增物料清單</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="AssetCreate" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label class="control-label">資產大類 <span class="text-danger">*</span></label>
                <select id="MainCategoryDropdown" class="form-select" asp-items="ViewBag.MainCategoryList" required>
                    <option value="">請選擇大類...</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">資產類別 <span class="text-danger">*</span></label>
                <select id="SubCategoryDropdown" class="form-select" required>
                    <option value="">請先選擇大類...</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="IN_ID" class="control-label">資產品名 <span class="text-danger">*</span></label>
                <select id="ItemNameDropdown" asp-for="IN_ID" class="form-select" required>
                    <option value="">請先選擇類別...</option>
                </select>
                <span asp-validation-for="IN_ID" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="MODEL" class="control-label">型號</label>
                <input asp-for="MODEL" class="form-control" placeholder="請輸入型號 (選填)" />
                <span asp-validation-for="MODEL" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="BRAND" class="control-label">廠牌</label>
                <input asp-for="BRAND" class="form-control" placeholder="請輸入廠牌 (選填)" />
                <span asp-validation-for="BRAND" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="UNIT_ID" class="control-label">標準單位 <span class="text-danger">*</span></label>
                <select asp-for="UNIT_ID" class="form-select" asp-items="ViewBag.UnitList" required>
                    <option value="">請選擇單位...</option>
                </select>
                <span asp-validation-for="UNIT_ID" class="text-danger"></span>
            </div>

            <div class="form-group mt-4">
                <input type="submit" value="確認新增" class="btn btn-primary" />
                <a asp-action="AssetIndex" class="btn btn-secondary">返回清單</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // 等待 HTML 畫面完全載入後執行
        document.addEventListener("DOMContentLoaded", function () {

            // 🌟 SweetAlert2 提示視窗邏輯
            // 從後端接收成功或錯誤訊息
            var successMsg = '@Html.Raw(TempData["SuccessMessage"])';
            var errorMsg = '@Html.Raw(TempData["ErrorMessage"])';

            if (successMsg) {
                Swal.fire({
                    icon: 'success',
                    title: '成功！',
                    text: successMsg,
                    confirmButtonColor: '#3085d6'
                });
            }

            if (errorMsg) {
                Swal.fire({
                    icon: 'error',
                    title: '新增失敗！',
                    text: errorMsg,
                    confirmButtonColor: '#d33'
                });
            }

            // 🌟 以下為連動下拉選單的 AJAX 邏輯
            document.getElementById('MainCategoryDropdown').addEventListener('change', function () {
                var mainCatId = this.value;
                var subDropdown = document.getElementById('SubCategoryDropdown');
                var itemDropdown = document.getElementById('ItemNameDropdown');

                subDropdown.innerHTML = '<option value="">請選擇類別...</option>';
                itemDropdown.innerHTML = '<option value="">請先選擇類別...</option>';

                if (mainCatId) {
                    fetch(`/AssetInfo/GetSubCategories?mainCatId=${mainCatId}`)
                        .then(response => response.json())
                        .then(data => {
                            data.forEach(item => {
                                let option = new Option(item.text, item.value);
                                subDropdown.add(option);
                            });
                        })
                        .catch(error => console.error('Error fetching sub categories:', error));
                }
            });

            document.getElementById('SubCategoryDropdown').addEventListener('change', function () {
                var subCatId = this.value;
                var itemDropdown = document.getElementById('ItemNameDropdown');

                itemDropdown.innerHTML = '<option value="">請選擇品名...</option>';

                if (subCatId) {
                    fetch(`/AssetInfo/GetItemNames?subCatId=${subCatId}`)
                        .then(response => response.json())
                        .then(data => {
                            data.forEach(item => {
                                let option = new Option(item.text, item.value);
                                itemDropdown.add(option);
                            });
                        })
                        .catch(error => console.error('Error fetching item names:', error));
                }
            });
        });
    </script>
}