@model Web_EAMSystem.Models.StorageBin

@{
    ViewData["Title"] = "新增儲位";
}

<h2>新增儲位資料</h2>
<hr />

<div class="row">
    <div class="col-md-5">
        <form asp-action="StorageBinCreate" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="ROOM_ID" class="control-label">所屬資材室 <span class="text-danger">*</span></label>
                <select asp-for="ROOM_ID" class="form-select" asp-items="ViewBag.RoomList" required>
                    <option value="">請選擇資材室...</option>
                </select>
                <span asp-validation-for="ROOM_ID" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="BIN_CODE" class="control-label">庫位號碼 <span class="text-danger">*</span></label>
                <div class="input-group">
                    <span class="input-group-text bg-light text-muted">自動加上前綴_</span>
                    <input asp-for="BIN_CODE" class="form-control" placeholder="例如: 1-1 或 01" required />
                </div>
                <small class="text-muted">系統存檔時，會自動組合為「資材室名稱_庫位號碼」（例如：A_1-1）</small>
                <span asp-validation-for="BIN_CODE" class="text-danger"></span>
            </div>

            <div class="form-group mt-4">
                <input type="submit" value="確認新增" class="btn btn-primary" />
                <a asp-action="StorageBinIndex" class="btn btn-secondary">返回清單</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var successMsg = '@Html.Raw(TempData["SuccessMessage"])';
            var errorMsg = '@Html.Raw(TempData["ErrorMessage"])';

            if (successMsg) {
                Swal.fire({ icon: 'success', title: '成功！', text: successMsg, confirmButtonColor: '#3085d6' });
            }
            if (errorMsg) {
                Swal.fire({ icon: 'error', title: '發生錯誤！', text: errorMsg, confirmButtonColor: '#d33' });
            }
        });
    </script>
}