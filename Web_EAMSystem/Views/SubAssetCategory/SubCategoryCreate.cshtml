@model Web_EAMSystem.Models.SubAssetCategory
@{
    ViewData["Title"] = "新增子類別";
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

    <style>
        /* 針對 Select2 展開後的搜尋框進行樣式修改 */
        .select2-container--default .select2-search--dropdown .select2-search__field {
            /* 1. 放入放大鏡 SVG 圖示作為背景 */
            background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="%236c757d" viewBox="0 0 16 16"><path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/></svg>');
            background-repeat: no-repeat;
            background-position: 10px center;
            padding-left: 32px;
            border-radius: 4px;
            border: 1px solid #ced4da;
        }
    </style>
}

<h2>新增資產子類別</h2>

<div class="row mt-4">
    <div class="col-md-6">
        <form asp-action="SubCategoryCreate" method="post">

            <div class="form-group mb-3">
                <label asp-for="MAIN_CAT_CODE" class="control-label">所屬大類</label>
                <select asp-for="MAIN_CAT_CODE" id="mainCategorySelect" class="form-select" asp-items="@ViewBag.MainCategoryList">
                    <option value="">-- 請選擇所屬大類 --</option>
                </select>
                <span asp-validation-for="MAIN_CAT_CODE" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="SUB_CAT_CODE" class="control-label">類別代號</label>
                <input asp-for="SUB_CAT_CODE" class="form-control" placeholder="例如：NB" />
                <span asp-validation-for="SUB_CAT_CODE" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="SUB_CAT_NAME" class="control-label">類別名稱</label>
                <input asp-for="SUB_CAT_NAME" class="form-control" placeholder="例如：筆記型電腦" />
                <span asp-validation-for="SUB_CAT_NAME" class="text-danger"></span>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary">存檔並送出</button>
                <a asp-action="SubCategoryIndex" class="btn btn-secondary">返回列表</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    @{
        // 載入前端防呆驗證
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // 等待 HTML 畫面完全載入後執行
        document.addEventListener("DOMContentLoaded", function () {

            // --- 1. 處理 SweetAlert2 提示訊息 ---
            var successMsg = '@Html.Raw(TempData["SuccessMessage"])';
            var errorMsg = '@Html.Raw(TempData["ErrorMessage"])';

            if (successMsg) {
                Swal.fire({
                    icon: 'success',
                    title: '成功！',
                    text: successMsg,
                    confirmButtonColor: '#3085d6'
                });
            }

            if (errorMsg) {
                Swal.fire({
                    icon: 'error',
                    title: '新增失敗！',
                    text: errorMsg,
                    confirmButtonColor: '#d33'
                });
            }

            // --- 2. 啟動 Select2 下拉搜尋功能 ---
            $('#mainCategorySelect').select2({
                placeholder: "-- 請選擇所屬大類 --",
                allowClear: true,
                width: '100%',
                language: {
                    noResults: function () {
                        return "找不到符合的大類";
                    }
                }
            });
        });
    </script>
}